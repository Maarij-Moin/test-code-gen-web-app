# ---------------------------------------------------------------------------
# Autonomous AI Testing Platform - Docker environment example
# Copy this file to .env before running docker compose.
# ---------------------------------------------------------------------------

PROJECT_NAME=Autonomous AI Testing Platform
IMAGE_TAG=latest
DEBUG=false

# Public ports on the Docker host
FRONTEND_PORT=8080
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
CHROMADB_PORT=8001

# Security
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Shared API key used by protected test-generation endpoints.
# Generate with: openssl rand -hex 32
API_KEY=change-this-api-key

# GitHub webhook signature secret, if GitHub webhooks are enabled.
GITHUB_WEBHOOK_SECRET=

# CORS origins accepted by FastAPI when backend is called directly.
# In normal Docker Compose usage, the browser calls frontend /api on the same origin.
ALLOWED_ORIGINS=["http://localhost","http://localhost:8080","http://127.0.0.1:8080"]

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_test_db

# Celery
CELERY_CONCURRENCY=2

# Optional AWS deployment values
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
ECR_BACKEND_REPOSITORY=autonomous-ai-testing-backend
ECR_FRONTEND_REPOSITORY=autonomous-ai-testing-frontend
