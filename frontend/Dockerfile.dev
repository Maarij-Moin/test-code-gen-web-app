# =============================================================================
# Dockerfile.dev — Minimal frontend dev image (used by docker-compose.override)
# =============================================================================
# This image is only used in development.  It installs pnpm and mounts the
# host source directory, so the Vite dev server picks up changes in real time.
# =============================================================================

FROM node:22-alpine AS dev

WORKDIR /app

# Install pnpm globally
RUN npm install -g pnpm@9.12.3

# Pre-install dependencies (overridden by bind-mount in compose)
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

EXPOSE 5173

CMD ["pnpm", "dev", "--host", "0.0.0.0", "--port", "5173"]
