# =============================================================================
# Autonomous AI Testing Platform — Environment Variables
# =============================================================================
# Copy to .env and fill in all secrets before running docker compose.
# Lines starting with # are comments and are ignored.
# DO NOT commit .env to version control.
# =============================================================================

# ── General ───────────────────────────────────────────────────────────────────
PROJECT_NAME=Autonomous AI Testing Platform
IMAGE_TAG=latest
DEBUG=false

# ── Host ports (Docker → host port mapping) ───────────────────────────────────
FRONTEND_PORT=8080
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
CHROMADB_PORT=8001
FLOWER_PORT=5555

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-jwt-secret-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Shared API key for test-generation endpoints (used by nginx X-API-Key header)
# Generate with: openssl rand -hex 32
API_KEY=change-this-api-key-use-openssl-rand-hex-32

# ── GitHub ────────────────────────────────────────────────────────────────────
# Webhook secret — must match the value set in GitHub repo → Settings → Webhooks
# Leave blank to disable signature verification (NOT recommended in production)
GITHUB_WEBHOOK_SECRET=

# Personal access token for creating pull requests via the pr_agent
GITHUB_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origins that may call the FastAPI backend directly (browsers).
# In Docker Compose the browser calls /api through nginx, so adjust accordingly.
ALLOWED_ORIGINS=["http://localhost","http://localhost:8080","http://127.0.0.1:8080"]

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_test_db

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=2

# ── Flower (Celery monitoring UI — http://localhost:5555/flower) ──────────────
FLOWER_USER=admin
FLOWER_PASSWORD=change-this-flower-password

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: mock | openai | azure | ollama
# mock  = deterministic scaffold, no API key required (safe for CI)
# openai = OpenAI API (requires OPENAI_API_KEY)
# azure  = Azure OpenAI (requires OPENAI_API_KEY + OPENAI_BASE_URL + AZURE_API_VERSION)
# ollama = local Ollama server (set OPENAI_BASE_URL to http://host.docker.internal:11434/v1)
LLM_PROVIDER=mock

# OpenAI / Azure / Ollama API key
OPENAI_API_KEY=

# Model name — gpt-4o-mini | gpt-4o | gpt-4-turbo | llama3 (Ollama) …
OPENAI_MODEL=gpt-4o-mini

# Base URL override (Azure endpoint or Ollama)
# Azure:  https://<resource>.openai.azure.com
# Ollama: http://host.docker.internal:11434/v1
OPENAI_BASE_URL=

# Azure OpenAI API version
AZURE_API_VERSION=2024-05-01-preview

# Generation parameters
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# ── Validation pipeline ───────────────────────────────────────────────────────
# Subprocess timeout for pytest/jest/mvn per generated file
VALIDATION_TIMEOUT_SECONDS=120
# Maximum LLM repair attempts per failing test file
VALIDATION_MAX_REPAIRS=3

# ── Optional AWS deployment ───────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
ECR_BACKEND_REPOSITORY=autonomous-ai-testing-backend
ECR_FRONTEND_REPOSITORY=autonomous-ai-testing-frontend
